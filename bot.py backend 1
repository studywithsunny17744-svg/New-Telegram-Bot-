# --- Generic OSINT Handler ---
async def handle_osint_command(update, context, base_url, api_key, search_type, param_name, emoji="🔍", title="Search"):
    if not await track_user(update): return
    await database.log_activity(update.effective_user.id, search_type)
    
    if not context.args:
        await update.message.reply_text(
            err_box("INVALID SYNTAX", f"📝 `/{search_type} <{param_name}>`"),
            parse_mode=constants.ParseMode.MARKDOWN
        )
        return

    term = " ".join(context.args)
    progress_msg = await update.message.reply_text(
        load_box("SCANNING...", f"{emoji} {title}\n🎯 Target: `{term}`"),
        parse_mode=constants.ParseMode.MARKDOWN
    )
    await update.message.chat.send_action(constants.ChatAction.TYPING)

    final_param = param_name if api_key == "NONE" else "term"
    url = f"{base_url}?{final_param}={term}"
    if api_key != "NONE":
        url += f"&key={api_key}"
    if search_type != "NONE":
        url += f"&type={search_type}"
    
    response = await fetch_api_data(url)
    result_text = format_response(response, term, title)
    await progress_msg.edit_text(result_text, parse_mode=constants.ParseMode.MARKDOWN)

def format_response(response, term, title):
    if not response:
        return err_box("CONNECTION FAILED", "Server did not respond. Try again.")
    
    try:
        json_data = response.json()
    except:
        json_data = None

    if response.status_code not in [200, 201, 202]:
        err = ""
        if json_data and (json_data.get("message") or json_data.get("error")):
            err = json_data.get('message') or json_data.get('error')
        else:
            err = f"HTTP {response.status_code}"
        return err_box("API ERROR", f"⚠️ {err}")
    
    try:
        if isinstance(json_data, dict):
            if json_data.get("status") == "error" or json_data.get("error") is True:
                return err_box("LOOKUP FAILED", f"⚠️ {json_data.get('message', 'Unknown error')}")

            # Remove unwanted fields
            for key in ["owner", "success", "cached", "proxyUsed", "attempt",
                        "developer", "developerinfo", "Developerinfo", "developerInfo", "DeveloperInfo"]:
                json_data.pop(key, None)
            
            results = json_data.get("result", {}).get("results", []) if isinstance(json_data.get("result"), dict) else json_data.get("result", [])
            
            if results and isinstance(results, list):
                body = f"🎯 Query: `{term}`\n\n"
                for idx, record in enumerate(results[:5], 1):
                    body += f"╔═ 📄 *Record {idx}* ═╗\n"
                    for k, v in record.items():
                        if v:
                            body += f"┃ ▸ *{k.replace('_',' ').title()}:* `{v}`\n"
                    body += f"╚{'═'*18}╝\n\n"
                return ok_box(title.upper(), body)
            
            body = ""
            for k, v in json_data.items():
                if v and "developer" not in k.lower():
                    body += f"▸ *{k.replace('_',' ').title()}:* `{v}`\n"
            return ok_box(title.upper(), body)
            
        return ok_box(title.upper(), f"`{response.text[:800]}`")
    except Exception as e:
        logging.error(f"Formatting error: {e}")
        return ok_box(title.upper(), f"`{response.text[:800]}`")

