@admin_only
async def broadcast(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.args:
        await update.message.reply_text(err_box("USAGE", "`/broadcast <message>`"), parse_mode=constants.ParseMode.MARKDOWN)
        return
    msg_text = " ".join(context.args)
    users = await database.get_all_users()
    broadcast_msg = ok_box("ANNOUNCEMENT", msg_text)
    count = 0
    for uid in users:
        try:
            await context.bot.send_message(uid, broadcast_msg, parse_mode=constants.ParseMode.MARKDOWN)
            count += 1
        except: pass
    await update.message.reply_text(ok_box("BROADCAST SENT", f"📨 Delivered to `{count}` users."), parse_mode=constants.ParseMode.MARKDOWN)

