# --- Helper ---
async def fetch_api_data(url):
    try:
        async with httpx.AsyncClient(timeout=60.0, follow_redirects=True) as client:
            response = await client.get(url)
        return response
    except Exception as e:
        logging.error(f"API Request Error: {e}")
        return None

def box(title, icon, body):
    """Unified compact message builder"""
    return f"\n{H}\n{icon} *{title}*\n{L}\n\n{body}\n{FOOTER}"

def err_box(title, body):
    return box(title, "🔻", body)

def ok_box(title, body):
    return box(title, "🔰", body)

def load_box(title, body):
    return box(title, "⏳", body)

