async def track_user(update: Update):
    if not update.effective_user:
        return True
    user = update.effective_user
    await database.add_or_update_user(user.id, user.username, user.first_name, user.last_name)
    if await database.is_banned(user.id):
        if update.message:
            await update.message.reply_text(
                err_box("ACCESS DENIED", "🚫 Your account is *suspended*.\nContact admin for appeal."),
                parse_mode=constants.ParseMode.MARKDOWN
            )
        return False
    if user.id not in ADMIN_IDS:
        can_use, used, limit = await database.check_daily_limit(user.id)
        if not can_use:
